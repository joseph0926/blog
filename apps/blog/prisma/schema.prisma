generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FormFactor {
  desktop
  mobile
}

enum Environment {
  prod
  dev
}

model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slug      String   @unique

  title       String
  description String
  thumbnail   String?

  tags Tag[]

  @@index([createdAt, id])
}

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String @unique

  posts Post[]
}

